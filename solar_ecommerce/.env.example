# ── Django Backend ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,<your-droplet-ip>
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Static files / local persistence
SQLITE_PATH=/app/data/db.sqlite3

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Security toggles
# For plain local HTTP testing only, temporarily set these to False / 0.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_COOKIES=True
DJANGO_SECURE_HSTS_SECONDS=31536000

# Optional PostgreSQL override
USE_POSTGRES=False
DB_NAME=solar_db
DB_USER=solar_user
DB_PASSWORD=change-me-strong-password
DB_HOST=
DB_PORT=5432

# ── Next.js Frontend ─────────────────────────────────────────────────────────
# The base URL the browser uses to reach the Django API (through Nginx).
# Just the origin — no /api suffix. The frontend code adds /api/... paths.
NEXT_PUBLIC_API_BASE_URL=http://<your-droplet-ip>
