# ── Django ────────────────────────────────────────────────────────────────────
# Generate your own:  python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-droplet-ip

# Comma-separated; add your frontend origin once deployed
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_NAME=solar_db
DB_USER=solar_user
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# ── Gunicorn tuning ───────────────────────────────────────────────────────────
# Rule of thumb: 2 × CPU cores + 1
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
