# ── Django Backend ────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-50-chars-minimum
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=138.197.11.80,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://138.197.11.80
CORS_ALLOWED_ORIGINS=http://138.197.11.80

# Static files / local persistence
SQLITE_PATH=/app/data/db.sqlite3

# Gunicorn (use 2 workers for 512MB RAM droplet)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Security toggles
# Set to True only after you have SSL/domain configured
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_COOKIES=False
DJANGO_SECURE_HSTS_SECONDS=0

# Optional PostgreSQL override (leave DB_HOST empty to use SQLite)
USE_POSTGRES=False
DB_NAME=solar_db
DB_USER=solar_user
DB_PASSWORD=change-me-strong-password
DB_HOST=
DB_PORT=5432

# ── Next.js Frontend ─────────────────────────────────────────────────────────
# The base URL the browser uses to reach the Django API (through Nginx).
# Just the origin — no /api suffix. The frontend code adds /api/... paths.
NEXT_PUBLIC_API_BASE_URL=http://138.197.11.80
